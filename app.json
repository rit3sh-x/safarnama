{
    "expo": {
        "name": "Safarnama",
        "slug": "safarnama",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "src/assets/app/icon.png",
        "scheme": "safarnama",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.safarnama",
            "infoPlist": {
                "NSFaceIDUsageDescription": "This app uses Face ID to securely log you into your account."
            }
        },
        "android": {
            "package": "com.safarnama",
            "adaptiveIcon": {
                "backgroundColor": "#0A0A0A",
                "foregroundImage": "src/assets/app/android-icon-foreground.png",
                "monochromeImage": "src/assets/app/android-icon-monochrome.png"
            },
            "edgeToEdgeEnabled": true,
            "predictiveBackGestureEnabled": false,
            "permissions": [
                "android.permission.USE_BIOMETRIC",
                "android.permission.USE_FINGERPRINT"
            ]
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "src/assets/app/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "expo-secure-store",
            [
                "expo-notifications",
                {
                    "icon": "src/assets/app/android-icon-foreground.png",
                    "color": "#D4F265"
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}